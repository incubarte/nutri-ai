# Storage Provider Configuration
# Opciones válidas:
#   - local: Lee y escribe archivos directamente en la carpeta /storage/data del proyecto.
#   - supabase_ro: Lee desde Supabase Storage (read-only, usa SUPABASE_ANON_KEY).
#   - supabase_rw: Lee y escribe en Supabase Storage (read/write, usa SUPABASE_SERVICE_KEY).
STORAGE_PROVIDER=local

# Poner en 'true' para deshabilitar todas las páginas de edición y controles, útil para mostrar solo el scoreboard.
NEXT_PUBLIC_READ_ONLY=false

# --- Supabase Configuration ---
